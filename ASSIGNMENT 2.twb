      <aliases enabled='yes' />
      <column caption='delivery status' datatype='string' name='[Calculation_0816171673133056]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Delivery_Time_Min]&lt;=30 then &quot;fast&quot;&#13;&#10;ELSE &quot;Deleyed&quot;&#13;&#10;END' />
      </column>
      <column caption='is loss' datatype='string' name='[Calculation_0816171673845761]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Profit]&lt;0 then &quot;loos&quot;&#13;&#10;ELSE &quot;Profit&quot;&#13;&#10;END' />
      </column>
      <column caption='CITY LEVEL BENCHMARKING' datatype='real' name='[Calculation_0816171695398915]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [City]:AVG([Sales]) }' />
      </column>
      <column caption='PRODUCT DETAILS IMPACT' datatype='real' name='[Calculation_0816171695824900]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG({ INCLUDE [Product_Name]:SUM([Sales]) })' />
      </column>
